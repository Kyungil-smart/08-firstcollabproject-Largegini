%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: LocalTable_ko
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: ko
  m_SharedData: {fileID: 11400000, guid: aac8ceb655d3e9940afa077145e80ad1, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 10001
    m_Localized: "\uCC28\uAC11\uACE0 \uCD95\uCD95\uD55C \uD759\uB0C4\uC0C8... \uC8FD\uC74C\uC870\uCC28
      \uD5C8\uB77D\uB418\uC9C0 \uC54A\uC740 \uAC83\uC778\uAC00."
    m_Metadata:
      m_Items: []
  - m_Id: 10002
    m_Localized: "\uB0B4 \uC721\uC2E0\uC740 \uC5B4\uB514 \uAC00\uACE0, \uC624\uC9C1
      \uBD80\uC2A4\uB7EC\uC9C0\uB294 \uBF1B\uC870\uAC01\uB4E4\uB9CC\uC774 \uB098\uB97C
      \uC9C0\uD0F1\uD558\uACE0 \uC788\uAD6C\uB098."
    m_Metadata:
      m_Items: []
  - m_Id: 10003
    m_Localized: "\uC800 \uBE44\uCC9C\uD55C \uC9D0\uC2B9 \uB188\uC774... \uAC10\uD788!
      \uB0B4 \uC544\uB0B4\uC640 \uC544\uC774\uAC00 \uC7A0\uB4E0 \uACF3\uC744 \uD30C\uD5E4\uCE58\uACE0
      \uC788\uB2E8 \uB9D0\uC774\uB0D0!"
    m_Metadata:
      m_Items: []
  - m_Id: 10004
    m_Localized: "\uB124\uB188\uC758 \uADF8 \uB354\uB7EC\uC6B4 \uC774\uBE68\uC774
      \uB0B4 \uC18C\uC911\uD55C \uAE30\uC5B5\uC744 \uC539\uC5B4 \uC0BC\uD0A4\uAC8C
      \uB450\uC9C0 \uC54A\uACA0\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 20001
    m_Localized: "\uD06C\uB974\uB974... \uBD84\uBA85 \uC0AC\uC2E0\uB2D8\uAED8\uC11C
      \uC228\uD1B5\uC744 \uB04A\uC5B4\uBC84\uB9B0 \uC655\uC758 \uC2DC\uCCB4\uC600\uAC70\uB298.
      \uB124\uB188\uC758 \uC6D0\uD55C\uC774 \uC5BC\uB9C8\uB098 \uAE4A\uAE38\uB798,
      \uC8FD\uC74C\uC758 \uAC15\uC744 \uAC70\uC2AC\uB7EC \uAE30\uC5B4 \uC62C\uB77C\uC654\uB2E8
      \uB9D0\uC774\uB0D0!"
    m_Metadata:
      m_Items: []
  - m_Id: 20002
    m_Localized: "\uBE44\uBA85\uC740 \uACE7 \uADF8\uCE60 \uAC83\uC774\uB2E4. \uB124\uB188\uC758
      \uBAA9\uC744 \uCE60 \uB54C \uC0DD\uAE30\uB294 \uD30C\uC5F4\uC74C\uC774 \uADF8
      \uC790\uB9AC\uB97C \uB300\uC2E0\uD560 \uD14C\uB2C8\uAE4C."
    m_Metadata:
      m_Items: []
  - m_Id: 20003
    m_Localized: "\uC785\uB9CC \uC0B4\uC544\uC788\uB294 \uD574\uACE8\uBC14\uAC00\uC9C0\uB85C\uAD70!
      \uB124\uB188\uC774 \uB2E4\uC2A4\uB9AC\uB358 \uBC31\uC131\uB4E4\uC758 \uBE44\uBA85\uC774
      \uC544\uC9C1\uB3C4 \uC774 \uC0B0\uB9E5\uC5D0 \uC6B8\uB824 \uD37C\uC9C0\uACE0
      \uC788\uB294\uB370, \uC655\uC774\uB780 \uC790\uAC00 \uD63C\uC790 \uC0B4\uC544
      \uB3CC\uC544\uC640 \uBCF5\uC218\uB97C \uB17C\uD55C\uB2E8 \uB9D0\uC774\uB0D0!"
    m_Metadata:
      m_Items: []
  - m_Id: 20004
    m_Localized: "\uC0AC\uC2E0\uC5D0\uAC8C \uC804\uD574\uB77C. \uC8FD\uC74C\uC870\uCC28
      \uB098\uB97C \uBD99\uC7A1\uC9C0 \uBABB\uD588\uC73C\uB2C8, \uC774\uC81C \uB0A8\uC740
      \uAC83\uC740 \uB124\uB188\uB4E4\uC758 \uC774 \uB354\uB7EC\uC6B4 \uC138\uC0C1\uC744
      \uBB34\uB108\uB728\uB9AC\uB294 \uAC83\uBFD0\uC774\uB77C\uACE0."
    m_Metadata:
      m_Items: []
  - m_Id: 20005
    m_Localized: "\uC2DC\uC791\uC740 \uB124\uB188\uC758 \uBD89\uC740 \uD53C\uB85C
      \uC774 \uD669\uB7C9\uD55C \uB545\uC744 \uC801\uC2DC\uB294 \uAC83\uBD80\uD130\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 20006
    m_Localized: "\uAC74\uBC29\uC9C4 \uAC83! \uC6D0\uD55C\uC73C\uB85C \uB2E4\uC2DC
      \uC6C0\uC9C1\uC774\uB294 \uC2DC\uCCB4\uB77C\uBA74, \uADF8 \uC6D0\uD55C\uC744
      \uAC00\uB8E8\uB85C \uB9CC\uB4E4\uC5B4 \uC601\uC6D0\uD788 \uC548\uC2DD\uD558\uC9C0
      \uBABB\uD558\uAC8C \uD574\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 20007
    m_Localized: "\uB124\uB188\uC758 \uB0A1\uC740 \uC655\uAD00\uACFC \uD568\uAED8,
      \uC774\uACF3\uC744 \uC9C4\uC815\uD55C \uB3C4\uC0B4\uC7A5\uC73C\uB85C \uB9CC\uB4E4\uC5B4\uC8FC\uC9C0!"
    m_Metadata:
      m_Items: []
  - m_Id: 20008
    m_Localized: "\uCD94\uC7A1\uD55C \uC6D0\uD55C\uC758 \uB0C4\uC0C8\uAC00 \uC774
      \uACE0\uC694\uD55C \uBE59\uD558\uAE4C\uC9C0 \uC2A4\uBA70\uB4E4\uC5C8\uAD6C\uB098.
      \uC0AC\uC2E0\uC758 \uB0AB\uC5D0 \uC601\uD63C\uC774 \uC798\uB824 \uB098\uAC04
      \uC655\uC774 \uC5B4\uCC0C\uD558\uC5EC \uB2E4\uC2DC \uCC28\uAC00\uC6B4 \uC228\uC744
      \uB0B4\uBC49\uACE0 \uC788\uB294 \uAC83\uC774\uB0D0."
    m_Metadata:
      m_Items: []
  - m_Id: 20009
    m_Localized: "\uB124\uB188\uC774 \uC5BC\uB824\uBC84\uB9B0 \uB0B4 \uBC31\uC131\uB4E4\uC758
      \uB208\uBB3C\uC774 \uC544\uC9C1 \uB9C8\uB974\uC9C0 \uC54A\uC558\uB2E4. \uADF8
      \uB208\uBB3C\uC774 \uACE0\uB4DC\uB984\uC774 \uB418\uC5B4 \uB124 \uC2EC\uC7A5\uC744
      \uAFF0\uB6AB\uAE30 \uC804\uAE4C\uC9C0\uB294, \uB098\uB294 \uC228\uC744 \uBA48\uCD9C
      \uC0DD\uAC01\uC774 \uC5C6\uAC70\uB4E0."
    m_Metadata:
      m_Items: []
  - m_Id: 20010
    m_Localized: "\uC5B4\uB9AC\uC11D\uAD6C\uB098. \uC778\uAC04\uC758 \uAC10\uC815
      \uB530\uC704\uB85C \uC8FD\uC74C\uC758 \uC12D\uB9AC\uB97C \uAC70\uC2A4\uB974\uB2E4\uB2C8.
      \uB124 \uC655\uAD6D\uC774 \uBB34\uB108\uC9C8 \uB54C \uBCF4\uC558\uB358 \uADF8
      \uBB34\uB825\uD568\uC744 \uBC8C\uC368 \uC78A\uC5C8\uB098 \uBCF8\uB370, \uC774\uBC88\uC5D0\uB294
      \uC6D0\uD55C\uC870\uCC28 \uC5BC\uC5B4\uBD99\uC5B4 \uBD80\uC11C\uC9C0\uAC8C
      \uD574\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 20011
    m_Localized: "\uC12D\uB9AC \uB530\uC704\uB294 \uC0AC\uC2E0\uACFC \uD568\uAED8
      \uBB34\uB364\uC5D0\uB098 \uB358\uC838\uC918\uB77C. \uB124\uB188\uC758 \uD478\uB978
      \uBE44\uB298\uC774 \uB0B4 \uAC80\uC220\uC758 \uC2DC\uD5D8\uB300\uAC00 \uB420
      \uAC83\uC774\uB2E4. \uC5BC\uC5B4\uBD99\uC740 \uC601\uC6D0\uC758 \uAC10\uC625\uC5D0\uC11C
      \uC601\uC6D0\uD788 \uC7A0\uB4E4 \uC900\uBE44\uB294 \uB418\uC5C8\uB098."
    m_Metadata:
      m_Items: []
  - m_Id: 20012
    m_Localized: "\uC655\uAD00\uC744 \uC4F4 \uB9DD\uB839\uC774\uC5EC, \uB124\uB188\uC758
      \uADF8 \uC624\uB9CC\uD55C \uB208\uB3D9\uC790\uBD80\uD130 \uC5BC\uB824\uC8FC\uC9C0.
      \uC774\uACF3\uC740 \uC0B0 \uC790\uB3C4, \uC8FD\uC740 \uC790\uB3C4 \uBA38\uBB34\uB97C
      \uC218 \uC5C6\uB294 \uC774 \uBAB8\uC758 \uC601\uD1A0\uB2E4!"
    m_Metadata:
      m_Items: []
  - m_Id: 20013
    m_Localized: "(\uC9D9\uC740 \uAC80\uC740 \uC548\uAC1C\uAC00 \uAC08\uB77C\uC9C0\uBA70,
      \uAC70\uB300\uD55C \uB0AB\uC744 \uB4E0 \uC0AC\uC2E0\uC774 \uD5C8\uACF5\uC5D0\uC11C
      \uB0B4\uB824\uC628\uB2E4.)"
    m_Metadata:
      m_Items: []
  - m_Id: 20014
    m_Localized: "\uAE30\uC5B4\uC774 \uB0B4\uAC00 \uADF8\uC5B4\uB193\uC740 \uC120\uC744
      \uB118\uACE0 \uC5EC\uAE30\uAE4C\uC9C0 \uB3C4\uB2EC\uD588\uAD6C\uB098."
    m_Metadata:
      m_Items: []
  - m_Id: 20015
    m_Localized: "\uC8FD\uC74C\uC758 \uD488 \uC548\uC5D0\uC11C \uC548\uC2DD\uC744
      \uAC70\uBD80\uD55C \uB9DD\uB839\uC774\uC5EC, \uADF8\uD1A0\uB85D \uBE44\uCC9C\uD55C
      \uC6D0\uD55C\uC774 \uB108\uB97C \uC6C0\uC9C1\uC774\uB294 \uB3D9\uB825\uC774\uC5C8\uB098."
    m_Metadata:
      m_Items: []
  - m_Id: 20016
    m_Localized: "\uC548\uC2DD? \uB0B4 \uBC31\uC131\uB4E4\uC758 \uC601\uD63C\uC744
      \uB0AB\uC73C\uB85C \uBCA0\uC5B4 \uB118\uAE38 \uB54C, \uADF8\uB4E4\uC5D0\uAC8C\uB3C4
      \uC548\uC2DD\uC744 \uBB3C\uC5C8\uB098."
    m_Metadata:
      m_Items: []
  - m_Id: 20017
    m_Localized: "\uB124\uB188\uC758 \uADF8 \uBB34\uC2EC\uD55C \uB208\uB3D9\uC790\uB97C
      \uB3C4\uB824\uB0B4\uC5B4, \uB0B4\uAC00 \uACAA\uC740 \uC9C0\uC625\uC744 \uADF8\uB300\uB85C
      \uBE44\uCDB0\uC8FC\uACE0 \uC2F6\uC5B4\uC11C \uC8FD\uC74C\uC870\uCC28 \uAC70\uBD80\uD588\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 20018
    m_Localized: "\uBB34\uC758\uBBF8\uD55C \uC9D1\uCC29\uC774\uAD70. \uB098\uB77C\uAC00
      \uBA78\uB9DD\uD558\uACE0 \uBC31\uC131\uC774 \uC0AC\uB77C\uC9C0\uB294 \uAC83\uC740
      \uD750\uB974\uB294 \uBB3C\uC774 \uC544\uB798\uB85C \uD5A5\uD558\uB294 \uAC83\uACFC
      \uAC19\uC740 \uC12D\uB9AC\uB2E4. \uB108 \uB610\uD55C \uADF8 \uD750\uB984\uC758
      \uC77C\uBD80\uC600\uC744 \uBFD0\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 20019
    m_Localized: "\uADF8 \uC12D\uB9AC\uB77C\uB294 \uAC83\uC744 \uB0B4\uAC00 \uC9C1\uC811
      \uAE68\uBD80\uC218\uB7EC \uC654\uB2E4. \uB0B4 \uC655\uAD00\uC774 \uBD80\uC11C\uC9C0\uACE0
      \uC2EC\uC7A5\uC774 \uBA48\uCDC4\uB358 \uADF8\uB0A0, \uB098\uB294 \uC778\uAC04\uC758
      \uC0B6\uC744 \uBC84\uB838\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 20020
    m_Localized: "\uC774\uC81C \uB0A8\uC740 \uAC83\uC740 \uC624\uC9C1 \uB124\uB188\uC758
      \uBAA9\uC744 \uCE58\uACE0, \uB124\uB188\uB4E4\uC774 \uB9CC\uB4E0 \uC138\uACC4\uB97C
      \uBB34\uB108\uB728\uB9B4 \uBFD0\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 20021
    m_Localized: "\uAC00\uB828\uD558\uAD6C\uB098. \uB124\uAC00 \uC954 \uADF8 \uBCF5\uC218\uC2EC\uC774
      \uC5BC\uB9C8\uB098 \uCC30\uB098\uC758 \uAC83\uC778\uC9C0 \uAE68\uB2EB\uAC8C
      \uD574\uC8FC\uB9C8. \uC2DC\uAC04\uC774 \uB2E4 \uB418\uBA74 \uB108\uC758 \uADF8
      \uAC70\uCC3D\uD55C \uC6D0\uD55C\uB3C4, \uC874\uC7AC\uB3C4, \uC601\uC6D0\uD55C
      \uB9DD\uAC01 \uC18D\uC73C\uB85C \uC0AC\uB77C\uC9C8 \uAC83\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 20022
    m_Localized: "\uC2DC\uAC04\uC774 \uB2E4 \uB418\uAE30 \uC804\uC5D0 \uB124\uB188\uC758
      \uBE44\uBA85\uBD80\uD130 \uB4E4\uC5B4\uC57C\uACA0\uC5B4. \uC624\uB298 \uC774\uACF3\uC740
      \uB124\uAC00 \uAC70\uB454 \uC601\uD63C\uB4E4\uC774 \uC544\uB2C8\uB77C, \uBC14\uB85C
      \uB124\uB188\uC758 \uBB34\uB364\uC774 \uB420 \uAC83\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 20023
    m_Localized: "\uC0AC\uC2E0\uC744 \uC4F0\uB7EC\uB728\uB9B0 \uC21C\uAC04, \uC601\uC6D0\uD560
      \uAC83 \uAC19\uB358 \uC804\uC7A5\uC758 \uD48D\uACBD\uC774 \uC870\uAC01\uB098\uAE30
      \uC2DC\uC791\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 20024
    m_Localized: "\uD0C0\uC624\uB974\uB358 \uBCF5\uC218\uC2EC\uC774 \uAEBC\uC9C0\uC790,
      \uC655\uC758 \uB9DD\uC9D1\uC73C\uB85C \uC720\uC9C0\uB418\uB358 \uD5C8\uAD6C\uC758
      \uC138\uACC4\uAC00 \uC18C\uBA78\uD558\uBA70 \uBCF8\uB798\uC758 \uACE0\uC694\uD55C
      \uBB34\uB364\uC73C\uB85C \uB3CC\uC544\uC628\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 20025
    m_Localized: "\uACF5\uC8FC\uC758 \uC601\uD63C \uC870\uAC01\uC774 \uC655\uC758
      \uAC00\uC2B4 \uC18D\uC5D0\uC11C \uD758\uB7EC\uB098\uC640 \uBE5B\uC758 \uD615\uCCB4\uB97C
      \uC774\uB8EC\uB2E4. \uBE5B \uC18D\uC5D0 \uB098\uD0C0\uB09C \uACF5\uC8FC\uAC00
      \uBF08\uB9CC \uB0A8\uC740 \uC544\uBC84\uC9C0\uB97C \uBD80\uB4DC\uB7FD\uAC8C
      \uAC10\uC2F8\uC548\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 20026
    m_Localized: "\uC774\uC81C \uCDA9\uBD84\uD574\uC694.. \uC774 \uBB34\uAC70\uC6B4
      \uCE7C\uC740 \uB0B4\uB824\uB193\uACE0 \uC6B0\uB9AC\uB791 \uAC19\uC774 \uD589\uBCF5\uD55C
      \uAFC8\uC744 \uAFD4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 20027
    m_Localized: "\uACF5\uC8FC\uC758 \uBAA9\uC18C\uB9AC\uAC00 \uB2FF\uC790, \uC655\uC744
      \uBD99\uB4E4\uACE0 \uC788\uB358 \uC9C0\uB3C5\uD55C \uC6D0\uD55C\uACFC \uC9D1\uCC29\uC774
      \uC53B\uACA8 \uB0B4\uB824\uAC04\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 20028
    m_Localized: "\uC655\uC740 \uB354 \uC774\uC0C1 \uBCF5\uC218\uC5D0 \uB208\uBA3C
      \uC790\uAC00 \uC544\uB2CC \uD3C9\uC628\uD55C \uC548\uC2DD\uC744 \uC55E\uB454
      \uC138\uB9B4\uB2E4 \uC655\uAD6D\uC758 \uC655\uC73C\uB85C \uB3CC\uC544\uAC04\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 20029
    m_Localized: "...\uADF8\uB798. \uC544\uC8FC \uAE34 \uAFC8\uC744 \uAFB8\uC5C8\uAD6C\uB098."
    m_Metadata:
      m_Items: []
  - m_Id: 20030
    m_Localized: "\uC774\uC81C\uC57C\u2026\uC274 \uC218 \uC788\uACA0\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 20031
    m_Localized: "\uB9DD\uC9D1\uC774 \uAC77\uD788\uACE0, \uBE44\uB85C\uC18C \uAE34
      \uBC24\uC774 \uB05D\uB0AC\uAD70\uC694. \uBD80\uB514 \uADF8\uACF3\uC5D0\uC120
      \uB2E4\uC2DC\uB294 \uCE7C\uC744 \uC7A1\uC9C0 \uC54A\uAE30\uB97C\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 20032
    m_Localized: "\uACB0\uAD6D\u2026 \uC774\uBC88 \uC0DD\uC758 \uBD88\uAF43\uB3C4
      \uC5EC\uAE30\uC11C \uC0AC\uADF8\uB77C\uB4DC\uB294\uAD70\uC694\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 20033
    m_Localized: "\uD0C0\uC624\uB974\uB358 \uBCF5\uC218\uC758 \uC99D\uC624\uB9C8\uC800
      \uCC28\uAC00\uC6B4 \uC7AC\uAC00 \uB418\uC5B4 \uD769\uC5B4\uC9C0\uB294 \uC774
      \uC21C\uAC04\uC774 \uC800\uB294 \uB9E4\uBC88 \uAC00\uC2B4\uC774 \uBF08\uC544\uD504\uAC8C
      \uC2DC\uB824\uC635\uB2C8\uB2E4\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 30001
    m_Localized: "\uD654\uB85C\uC758 \uBD88\uAF43\uC774 \uC544\uC9C1 \uC0B4\uC544\uC788\uAD70.
      \uBCF5\uC218\uC5D0 \uB05D\uC5D0 \uB3C4\uB2EC\uD558\uB824\uBA74 \uC9C0\uAE08\uBCF4\uB2E4
      \uB354 \uAC00\uD639\uD55C \uBB34\uC7A5\uC774 \uD544\uC694\uD574."
    m_Metadata:
      m_Items: []
  - m_Id: 30002
    m_Localized: "\uCE7C\uC744 \uB0A0\uCE74\uB86D\uAC8C \uBCBC\uB9B0\uB2E4. [\uACF5\uACA9
      +1]"
    m_Metadata:
      m_Items: []
  - m_Id: 30003
    m_Localized: "\uB354 \uB0A0\uCE74\uB86D\uAC8C \uAC08\uC544\uC57C \uD55C\uB2E4.
      \uB140\uC11D\uB4E4\uC758 \uC228\uD1B5\uC744 \uB2E8\uC228\uC5D0 \uB04A\uC5B4\uB0BC
      \uC218 \uC788\uB3C4\uB85D."
    m_Metadata:
      m_Items: []
  - m_Id: 30004
    m_Localized: "\uB179\uC2A8 \uAC11\uC8FC\uB97C \uAC1C\uC870\uD55C\uB2E4. [\uBC29\uC5B4
      +1]"
    m_Metadata:
      m_Items: []
  - m_Id: 30005
    m_Localized: "\uB179\uC2A8 \uAC11\uC8FC\uB97C \uD138\uC5B4\uB0B4\uACE0 \uB0B4
      \uBF08\uB9C8\uB514\uC5D0 \uB9DE\uAC8C \uB2E4\uC2DC \uBC84\uB824\uC57C \uD55C\uB2E4.
      \uC5B4\uB5A4 \uBC18\uACA9\uB3C4 \uD5C8\uC6A9\uD558\uC9C0 \uC54A\uC744 \uB9CC\uD07C
      \uB2E8\uB2E8\uD558\uAC8C."
    m_Metadata:
      m_Items: []
  - m_Id: 30006
    m_Localized: "\uC624\uC168\uB098\uC774\uAE4C, \uC804\uD558\u2026 \uCC28\uB514\uCC2C
      \uC5B4\uB460 \uC18D\uC5D0\uC11C\uB3C4 \uC800\uD76C\uB294 \uC624\uC9C1 \uC8FC\uAD70\uC758
      \uBC1C\uC18C\uB9AC\uB9CC\uC744 \uAE30\uB2E4\uB838\uC2B5\uB2C8\uB2E4. \\n \uBB34\uB2A5\uD55C
      \uAC83\uC740 \uC800\uD76C\uC600\uC73C\uB2C8, \uBD80\uB514 \uC790\uC2E0\uC744
      \uD0D3\uD558\uBA70 \uBA48\uCD94\uC9C0 \uB9C8\uC18C\uC11C.."
    m_Metadata:
      m_Items: []
  - m_Id: 30007
    m_Localized: "\uBC31\uC131\uB4E4\uC758 \uC228\uACB0\uB85C \uC0C1\uCC98\uB97C
      \uD68C\uBCF5\uD55C\uB2E4. [HP 50 \uD68C\uBCF5]"
    m_Metadata:
      m_Items: []
  - m_Id: 30008
    m_Localized: "\uC804\uD558... \uB354\uB294 \uC6B8\uC9C0 \uB9C8\uC18C\uC11C. \uC800\uD76C\uC758
      \uB0A8\uC740 \uC228\uACB0\uC744 \uBAA8\uC544 \uB2F9\uC2E0\uC758 \uC0C1\uCC98\uB97C
      \uBA54\uC6B0\uACA0\uB098\uC774\uB2E4. \uBD80\uB514 \uD138\uACE0 \uC77C\uC5B4\uB098
      \uD55C \uBC88 \uB354 \uAC78\uC5B4\uC8FC\uC18C\uC11C."
    m_Metadata:
      m_Items: []
  - m_Id: 30009
    m_Localized: "\uBC31\uC131\uB4E4\uC758 \uC0DD\uBA85\uB825\uC744 \uC2EC\uC7A5\uC5D0
      \uBD09\uD5CC\uD55C\uB2E4. [\uD68C\uBCF5+1]"
    m_Metadata:
      m_Items: []
  - m_Id: 30010
    m_Localized: "\uC804\uD558... \uC800\uD76C\uC758 \uB9C8\uC9C0\uB9C9 \uC0DD\uBA85\uB825\uC744
      \uBC1B\uC544\uC8FC\uC18C\uC11C. \uBE44\uB85D \uC601\uD63C\uC740 \uD769\uC5B4\uC9C8\uC9C0\uB77C\uB3C4,
      \uC804\uD558\uC758 \uC2EC\uC7A5\uC774 \uB418\uC5B4 \uADF8\uB987\uC744 \uCC44\uC6B0\uACA0\uB098\uC774\uB2E4.
      \uBD80\uB514 \uAEBE\uC774\uC9C0 \uB9C8\uC18C\uC11C."
    m_Metadata:
      m_Items: []
  - m_Id: 30011
    m_Localized: "\uBA3C\uC9C0 \uC313\uC778 \uBCD1\uBC95\uC11C\uB4E4\uC774 \uC5EC\uAE30
      \uB0A8\uC544 \uC788\uC5C8\uAD70. \uAECD\uB370\uAE30\uB294 \uC0AC\uB77C\uC84C\uC5B4\uB3C4
      \uC804\uC7A5\uC744 \uB4A4\uD754\uB4E4\uB358 \uADF8\uB0A0\uC758 \uC218\uC2F8\uC6C0\uB9CC\uD07C\uC740
      \uB2E4\uC2DC \uAE68\uC6CC\uB0B4\uC57C \uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30012
    m_Localized: "\uBCD1\uBC95\uC11C : \uAE30\uB3D9\uC758 \uC11C\uB97C \uC120\uD0DD\uD55C\uB2E4.
      [\uD2B9\uC218\uACF5\uACA9 +1]"
    m_Metadata:
      m_Items: []
  - m_Id: 30013
    m_Localized: "\uC801\uC758 \uD5C8\uB97C \uCC0C\uB974\uB294 \uCC30\uB098\uC758
      \uC6C0\uC9C1\uC784\uC774 \uC801\uD600 \uC788\uAD70. \uC774 \uC804\uC220\uC744
      \uB418\uC0C8\uAE30\uBA74 \uD55C \uBC88\uC758 \uAE30\uD68C\uB97C \uB354 \uC6C0\uCF1C\uC958
      \uC218 \uC788\uB2E4. \uB188\uB4E4\uC774 \uB300\uC751\uD558\uAE30 \uC804\uC5D0
      \uC228\uD1B5\uC744 \uB04A\uC5B4\uBC84\uB9AC\uACA0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30014
    m_Localized: "\uBCD1\uBC95\uC11C : \uC5F0\uACA9\uC758 \uC11C\uB97C \uC120\uD0DD\uD55C\uB2E4.
      [\uD589\uB3D9\uB825 \uAC8C\uC774\uC9C0 +1]"
    m_Metadata:
      m_Items: []
  - m_Id: 30015
    m_Localized: "\uC804\uD22C\uC758 \uD750\uB984\uC744 \uD0C0\uB294 \uBC95\uC774
      \uC801\uD600 \uC788\uAD70. \uD55C \uBC88\uC758 \uB3D9\uC791\uC774 \uB2E4\uC74C
      \uAE30\uD68C\uB85C \uB9E4\uB044\uB7FD\uAC8C \uC774\uC5B4\uC9C0\uB3C4\uB85D
      \uACF5\uACA9\uC758 \uD750\uB984\uC744 \uB354 \uAC00\uC18D\uD560 \uC218 \uC788\uACA0\uC5B4."
    m_Metadata:
      m_Items: []
  - m_Id: 30016
    m_Localized: "\uC624\uB290\uB77C \uACE0\uC0DD\uD588\uAD6C\uB824\u2026 \uD788\uD788\uD788\u2026
      \uACE0\uB2E8\uD55C \uC655\uC774\uC5EC. \\n \uAF3F\uAF3F\uD558\uAC8C \uBC84\uD168\uC628
      \uADF8\uB300\uC758 \uB4F1 \uB4A4\uB85C \uC9C0\uB3C5\uD55C \uC678\uB85C\uC6C0\uACFC
      \uBCF5\uC218\uC2EC\uC774 \uBCF4\uC774\uB294\uAD6C\uB824. \uC7A0\uC2DC \uC774
      \uB299\uC740\uC774\uC758 \uACC1\uC5D0\uC11C \uAE38\uC744 \uBB3C\uC5B4\uBCF4\uACE0
      \uAC00\uC2DC\uACA0\uC18C?"
    m_Metadata:
      m_Items: []
  - m_Id: 30017
    m_Localized: "\uB178\uD30C\uC758 \uC870\uC5B8\uC744 \uAD6C\uD55C\uB2E4. [\uACF5\uACA9
      +2, \uBC29\uC5B4 -1]"
    m_Metadata:
      m_Items: []
  - m_Id: 30018
    m_Localized: "\uAC00\uC5FE\uC740 \uC655\uC774\uC5EC\u2026 \uC774 \uB299\uC740\uC774\uC758
      \uB9D0\uC744 \uB4E4\uC73C\uB824\uBB34\uB098. \uB124 \uBAB8\uC744 \uC9C0\uD0AC
      \uC9C0\uD61C\uB294 \uC870\uAE08 \uD5C8\uC220\uD574\uC9C0\uACA0\uC9C0\uB9CC,
      \uADF8\uB9CC\uD07C \uB124 \uCE7C\uB0A0\uC774 \uC801\uC758 \uC2EC\uC7A5\uC744
      \uB354 \uAE4A\uC219\uC774 \uD30C\uACE0\uB4DC\uB294 \uD30C\uAD34\uC801\uC778
      \uC218\uB97C \uAC00\uB974\uCCD0\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 30019
    m_Localized: "\uB178\uD30C\uC5D0\uAC8C \uC548\uAE34\uB2E4. [HP -50%, \uD589\uB3D9\uB825
      \uAC8C\uC774\uC9C0 +1]"
    m_Metadata:
      m_Items: []
  - m_Id: 30020
    m_Localized: "\uD788\uD788\uD788\u2026\uADF8\uB798 \uAC00\uC5FE\uC740 \uC655\uC774\uC5EC.
      \uC774 \uC2DC\uB4E4\uC5B4\uAC00\uB294 \uD488\uC5D0 \uB354 \uAE4A\uC219\uC774
      \uC548\uAE30\uAC70\uB77C. \uB124 \uBAB8\uC744 \uC9C0\uD0F1\uD558\uB294 \uC0DD\uAE30
      \uC808\uBC18\uC744 \uAC00\uC838\uAC00\uB294 \uB300\uC2E0, \uB124 \uB9C8\uB978
      \uBF08\uB9C8\uB514\uAC00 \uC804\uBCF4\uB2E4 \uBE60\uB974\uAC8C \uBAB0\uC544\uCE58\uB3C4\uB85D
      \uB9CC\uB4E4\uC5B4\uC8FC\uB9C8."
    m_Metadata:
      m_Items: []
  - m_Id: 30021
    m_Localized: "\uBB34\uB108\uC9C4 \uD558\uB298 \uC544\uB798\uC11C\uB3C4 \uAE38\uC744
      \uCC3E\uC73C\uB7EC \uC624\uC168\uAD70\uC694. \uC774\uBBF8 \uCD94\uB77D\uD558\uC5EC
      \uBE5B\uC744 \uC783\uC740 \uC6B4\uBA85\uC774\uB77C \uD558\uB098, \uC77C\uADF8\uB7EC\uC9C4
      \uBCC4\uC758 \uADA4\uC801 \uC18D\uC5D0 \uB2E8 \uD558\uB098\uC758 \uAE30\uD68C\uB294
      \uB0A8\uC544 \uC788\uC744\uC9C0\uB2C8\u2026 \uADF8 \uAE38\uC744 \uBCF4\uC5EC\uB4DC\uB9B4\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 30022
    m_Localized: "\uC6B4\uBA85\uC758 \uC2E4\uD0C0\uB798\uB97C \uACB9\uCE5C\uB2E4.
      [30% \uD655\uB960\uB85C 50%\uC758 \uB370\uBBF8\uC9C0\uB97C \uCD94\uAC00\uB85C
      \uC785\uD78C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30023
    m_Localized: "\uBCC4\uB4E4\uC758 \uD750\uB984\uC774 \uACB9\uCE58\uB294\uAD70\uC694.
      \uB2F9\uC2E0\uC758 \uC27C \uC5C6\uB294 \uCE7C\uB0A0 \uC18D\uC5D0 \uC6B4\uBA85\uC758
      \uC2E4\uD0C0\uB798\uAC00 \uB9DE\uBB3C\uB824, \uB9E4 \uC21C\uAC04\uC740 \uC544\uB2C8\uB354\uB77C\uB3C4
      \uC5B4\uB290 \uCC30\uB098\uC5D0 \uADF8 \uB204\uAD6C\uB3C4 \uC608\uCE21\uC9C0
      \uBABB\uD55C \uAC70\uB300\uD55C \uC778\uACFC\uB97C \uBD88\uB7EC\uC62C \uAC83\uC774\uC624.
      \uD558\uB298\uC5D0 \uB9E1\uAE34 \uC6B4\uC744 \uBBFF\uC5B4\uBCF4\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    m_Metadata:
      m_Items: []
  - m_Id: 30024
    m_Localized: "\uC77C\uADF8\uB7EC\uC9C4 \uBBF8\uB798\uB97C \uC5FF\uBCF8\uB2E4.
      [10%\uC758 \uB370\uBBF8\uC9C0\uB97C \uCD94\uAC00\uB85C \uC785\uD78C\uB2E4.]"
    m_Metadata:
      m_Items: []
  - m_Id: 30025
    m_Localized: "\uC77C\uADF8\uB7EC\uC9C4 \uBBF8\uB798\uAC00 \uBCF4\uC785\uB2C8\uB2E4...
      \uCCAB\uAC78\uC74C\uC740 \uC804\uBCF4\uB2E4 \uBB34\uAC70\uC6CC\uC9C0\uACA0\uC73C\uB098,
      \uB2F9\uC2E0\uC774 \uD718\uB450\uB974\uB294 \uBAA8\uB4E0 \uAC80\uD48D \uC18D\uC5D0
      \uD53C\uD560 \uC218 \uC5C6\uB294 \uAC00\uD639\uD55C \uC6B4\uBA85\uC758 \uC870\uAC01\uC774
      \uAE43\uB4E4\uAC8C \uB420 \uAC83\uC774\uC624. \uB300\uAC00\uB294 \uB2F9\uC2E0\uC758
      \uC6B4\uBA85 \uADF8 \uC790\uCCB4\uAC00 \uAC10\uB2F9\uD574\uC57C \uD560 \uBAAB\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30026
    m_Localized: "\uC2E0\uC870\uCC28 \uACE0\uAC1C\uB97C \uB3CC\uB9B0 \uC774 \uD3D0\uD5C8\uC5D0
      \uBC1C\uC744 \uB4E4\uC774\uC2DC\uB2E4\uB2C8... \uAC00\uB828\uD55C \uC601\uD63C\uC774\uC5EC,
      \uB2F9\uC2E0\uC758 \uBD80\uC11C\uC9C4 \uBF08\uB9C8\uB514\uC5D0 \uC81C \uAE30\uB3C4\uAC00
      \uC791\uC740 \uC548\uC2DD\uC774 \uB420 \uC218 \uC788\uB2E4\uBA74 \uAE30\uAEBC\uC774
      \uADF8 \uC55E\uAE38\uC744 \uCD95\uBCF5\uD558\uACA0\uB098\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30027
    m_Localized: "\uC21C\uAD50\uC790\uC758 \uAE30\uB3C4\uB97C \uC218\uB77D\uD55C\uB2E4.
      [\uD68C\uBCF5-1, HP +20]"
    m_Metadata:
      m_Items: []
  - m_Id: 30028
    m_Localized: "...\uC774 \uAE30\uB3C4\uAC00 \uB2F9\uC2E0\uC758 \uAE38\uC5D0 \uD55C
      \uC90C\uC758 \uBE5B\uC774 \uB420 \uAC81\uB2C8\uB2E4. \uC0C1\uCC98\uB97C \uB418\uB3CC\uB9AC\uB294
      \uAE30\uC6B4\uC740 \uD76C\uBBF8\uD574\uC84C\uC9C0\uB9CC, \uB2F9\uC2E0\uC774\uB77C\uB294
      \uC874\uC7AC\uAC00 \uAC10\uB2F9\uD560 \uC218 \uC788\uB294 \uC601\uD63C\uC758
      \uBB34\uAC8C\uB294 \uC804\uBCF4\uB2E4 \uD6E8\uC52C \uAE4A\uACE0 \uB113\uC5B4\uC9C8
      \uAC83\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30029
    m_Localized: "\uB0A8\uACA8\uC9C4 \uC2E0\uC131\uD55C \uD798\uC744 \uCDE8\uD55C\uB2E4.
      [\uD68C\uBCF5+1, HP -10]"
    m_Metadata:
      m_Items: []
  - m_Id: 30030
    m_Localized: "\uC544\uBB34\uAC83\uB3C4 \uB4E4\uB9AC\uC9C0 \uC54A\uB294\uAD70\uC694\u2026
      \uC624\uC9C1 \uACF5\uD5C8\uD55C \uBE44\uBA85\uB9CC\uC774 \uC774 \uC131\uC18C\uB97C
      \uBA54\uC6B8 \uBFD0\uC785\uB2C8\uB2E4.\uB2F9\uC2E0\uC774 \uB2F4\uC744 \uC218
      \uC788\uB294 \uC0DD\uBA85\uC758 \uCD1D\uB7C9\uC740 \uAE4E\uC5EC\uB098\uAC00\uACA0\uC9C0\uB9CC,
      \uADF8 \uAE4A\uC740 \uD749\uD130\uB97C \uBA54\uC6B0\uB294 \uC2E0\uC131\uD55C
      \uD798\uB9CC\uD07C\uC740 \uADF8 \uC5B4\uB290 \uB54C\uBCF4\uB2E4 \uAC15\uB82C\uD558\uAC8C
      \uD0C0\uC624\uB97C \uAC83\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30031
    m_Localized: "\uBE5B\uC744 \uC783\uC740 \uB545\uC5D0\uC11C \uC5EC\uC804\uD788
      \uC99D\uC624\uB97C \uBD88\uD0DC\uC6B0\uB294 \uB208\uBA3C \uB9DD\uB839\uC774\uC5EC,
      \uB2F9\uC2E0\uC758 \uADF8 \uB05D\uC5C6\uB294 \uAC08\uC99D\uC744 \uCC44\uC6B8
      \uD798\uC744 \uB0B4\uC5B4\uB4DC\uB9AC\uC9C0\uC694. \uB2E4\uB9CC, \uC5BB\uB294
      \uAC83\uC774 \uC788\uB2E4\uBA74 \uC783\uB294 \uAC83\uB3C4 \uC788\uC5B4\uC57C
      \uD560 \uD130."
    m_Metadata:
      m_Items: []
  - m_Id: 30032
    m_Localized: "\uCC9C\uC0AC\uC758 \uC790\uBE44\uB85C\uC6B4 \uC190\uAE38\uC744
      \uBC1B\uC544\uB4E4\uC778\uB2E4. [HP 50% \uC774\uD558 \uC2DC, \uD68C\uBCF5 +2]"
    m_Metadata:
      m_Items: []
  - m_Id: 30033
    m_Localized: "\uC704\uAE30\uC758 \uC21C\uAC04, \uB2F9\uC2E0\uC758 \uAC04\uC808\uD568\uC774
      \uCE58\uC720\uC758 \uBE5B\uC774 \uB420 \uAC83\uC785\uB2C8\uB2E4. \uCCB4\uB825\uC774
      \uC808\uBC18 \uC774\uD558\uB85C \uB5A8\uC5B4\uC9C8 \uB54C, \uC131\uC2A4\uB7EC\uC6B4
      \uAE30\uC6B4\uC774 \uB2F9\uC2E0\uC758 \uC0C1\uCC98\uB97C \uB354 \uAE4A\uAC8C
      \uC5B4\uB8E8\uB9CC\uC9C8\uC9C0\uB2C8."
    m_Metadata:
      m_Items: []
  - m_Id: 30034
    m_Localized: "\uCC9C\uC0AC\uC758 \uC131\uC2A4\uB7EC\uC6B4 \uAC00\uD638\uB97C
      \uBAB8\uC5D0 \uB450\uB978\uB2E4. [HP50% \uC774\uC0C1 \uC2DC, \uBC29\uC5B4+1]"
    m_Metadata:
      m_Items: []
  - m_Id: 30035
    m_Localized: "\uCDA9\uB9CC\uD55C \uC0DD\uBA85\uB825\uC740 \uACE7 \uACAC\uACE0\uD55C
      \uBC29\uD328\uAC00 \uB429\uB2C8\uB2E4. \uB2F9\uC2E0\uC758 \uBAB8\uC774 \uC628\uC804\uD560
      \uB54C, \uD558\uB298\uC758 \uAC00\uD638\uAC00 \uAE43\uB4E0 \uBC29\uC5B4\uB9C9\uC774
      \uADF8 \uAE30\uC6B4\uC744 \uB354\uC6B1 \uB2E8\uB2E8\uD558\uAC8C \uC9C0\uCF1C\uC904
      \uAC83\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30036
    m_Localized: "\uD06C\uD06C\uD06C\u2026 \uC2EC\uC7A5\uC774 \uD0C0\uB4E4\uC5B4
      \uAC00\uB294 \uB0C4\uC0C8\uB97C \uB9E1\uACE0 \uCC3E\uC544\uC654\uC9C0. \uB124
      \uC601\uD63C\uC774 \uBD80\uC11C\uC9C0\uB294 \uAC83 \uB530\uC704 \uB0B4 \uC54C
      \uBC14 \uC544\uB2C8\uB2E4. \uC624\uC9C1 \uADF8 \uBCF5\uC218\uB97C \uB05D\uB0BC
      \uAC00\uD639\uD55C \uD798\uC744 \uC6D0\uD558\uB098? \uADF8\uB7FC, \uADF8\uC5D0
      \uD569\uB2F9\uD55C \uAC83\uC744 \uB0B4\uB193\uC544\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 30037
    m_Localized: "\uC545\uB9C8\uC640 \uACC4\uC57D\uD55C\uB2E4. [HP30%\uC774\uD558
      \uC2DC, \uACF5\uACA9+2]"
    m_Metadata:
      m_Items: []
  - m_Id: 30038
    m_Localized: "\uC88B\uB2E4. \uB124 \uC0DD\uBA85\uC774 \uAEBC\uC838\uAC00\uBA70
      \uC0AC\uC120\uC744 \uB118\uB098\uB4E4 \uB54C, \uB124\uAC00 \uD718\uB450\uB974\uB294
      \uBAA8\uB4E0 \uC77C\uACA9\uC5D0 \uC9C4\uC815\uD55C \uC7AC\uC559\uC758 \uC704\uB825\uC744
      \uB2F4\uC544\uC8FC\uB9C8. \uACC4\uC57D\uC740 \uC131\uB9BD\uB410\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30039
    m_Localized: "\uC545\uB9C8\uC5D0\uAC8C \uC0DD\uAE30\uB97C \uBC14\uCE5C\uB2E4.
      [HP40% \uC774\uD558 \uC2DC, \uD589\uB3D9\uB825 \uAC8C\uC774\uC9C0 +1]"
    m_Metadata:
      m_Items: []
  - m_Id: 30040
    m_Localized: "\uB124\uB188\uC758 \uC0DD\uAE30\uB97C \uC81C\uBB3C\uB85C \uBC1B\uC9C0.
      \uB300\uC2E0 \uB124 \uBAB8\uC744 \uAE30\uAD34\uD560 \uC815\uB3C4\uB85C \uBE60\uB974\uAC8C
      \uBAB0\uC544\uCE58\uB3C4\uB85D \uB9CC\uB4E4\uC5B4\uC8FC\uB9C8. \uADF8 \uCC30\uB098\uC758
      \uC21C\uAC04\uC774 \uB108\uC758 \uB9C8\uC9C0\uB9C9 \uBD88\uAF43\uC774 \uB420
      \uAC83\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30041
    m_Localized: "\uBC14\uB78C\uC758 \uACB0\uC774 \uBC14\uB00C\uC5C8\uAD70\uC694.
      \uC774 \uBA54\uB9C8\uB978 \uB545\uC5D0 \uC544\uC9C1 \uB9E5\uB3D9\uD558\uB294
      \uC2EC\uC7A5\uC774 \uB0A8\uC544\uC788\uC744 \uC904\uC774\uC57C... \uC232\uC758
      \uC544\uC774\uB4E4\uC774 \uB2F9\uC2E0\uC758 \uC0C1\uCC98 \uC785\uC740 \uC601\uD63C\uC5D0
      \uD638\uAE30\uC2EC\uC744 \uBCF4\uC774\uACE0 \uC788\uC2B5\uB2C8\uB2E4. \uADF8\uB4E4\uC758
      \uC7A5\uB09C\uC2A4\uB7EC\uC6B4 \uCD95\uBCF5\uC744 \uBC1B\uC544\uBCF4\uC2DC\uACA0\uC5B4\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 30042
    m_Localized: "\uC815\uB839\uC758 \uC0DD\uB3D9\uD558\uB294 \uD750\uB984\uC744
      \uD761\uC218\uD55C\uB2E4. [\uACF5\uACA9 \uB370\uBBF8\uC9C0\uC758 20%\uB9CC\uD07C
      HP\uB97C \uD68C\uBCF5\uD55C\uB2E4.]"
    m_Metadata:
      m_Items: []
  - m_Id: 30043
    m_Localized: "\uC232\uC758 \uC544\uC774\uB4E4\uC740 \uC0DD\uBA85\uC758 \uC870\uAC01\uC744
      \uC544\uC8FC \uC18C\uC911\uD788 \uC5EC\uAE34\uB2F5\uB2C8\uB2E4. \uADF8\uB4E4\uC774
      \uC8FC\uBCC0\uC5D0 \uD769\uC5B4\uC9C4 \uAE30\uC6B4\uC744 \uBAA8\uC544 \uB2F9\uC2E0\uC758
      \uBAB8\uC5D0 \uB530\uC2A4\uD558\uAC8C \uBCF4\uB4EC\uC5B4 \uD761\uC218\uC2DC\uCF1C
      \uC904 \uAC83\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 30044
    m_Localized: "\uC232\uC758 \uB9C8\uC9C0\uB9C9 \uAC00\uD638\uB97C \uC57D\uC18D\uBC1B\uB294\uB2E4.
      [HP50\uC744 \uD68C\uBCF5\uD558\uBA70 \uBD80\uD65C]"
    m_Metadata:
      m_Items: []
  - m_Id: 30045
    m_Localized: "\uC232\uC758 \uAC00\uD638\uB97C \uC57D\uC18D\uD569\uB2C8\uB2E4.
      \uB2F9\uC2E0\uC758 \uC0DD\uBA85 \uBD88\uAF43\uC774 \uC644\uC804\uD788 \uAEBC\uC838\uBC84\uB9AC\uB294
      \uCC30\uB098, \uC815\uB839\uB4E4\uC774 \uC790\uC2E0\uB4E4\uC758 \uBCF8\uC9C8\uC744
      \uD0DC\uC6CC \uB2F9\uC2E0\uC744 \uB2E4\uC2DC \uC774 \uC138\uC0C1\uC5D0 \uBD99\uC7A1\uC544\uB458
      \uAC83\uC785\uB2C8\uB2E4. \uB2E8 \uD55C \uBC88\uBFD0\uC778 \uAE30\uC801\uC784\uC744
      \uC78A\uC9C0 \uB9C8\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 40001
    m_Localized: "\uB098\uC758 \uC655\uC774\uC2DC\uC5EC. \uACB0\uAD6D \uB610\uB2E4\uC2DC
      \uB208\uC744 \uB728\uC168\uAD70\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 40002
    m_Localized: "\uB290\uAEF4\uC9C0\uB098\uC694. \uC774 \uB054\uCC0D\uD55C \uAD74\uB808
      \uC18D\uC5D0\uC11C \uBA48\uCD94\uC9C0 \uC54A\uB294 \uB2F9\uC2E0\uC744 \uC774\uB044\uB294...
      \uAC70\uBD80\uD560 \uC218 \uC5C6\uB294 \uBCF4\uC774\uC9C0 \uC54A\uB294 \uC190\uC774."
    m_Metadata:
      m_Items: []
  - m_Id: 40003
    m_Localized: "\uBD80\uB514 \uC774\uBC88\uC5D0\uB294\u2026 \uADF8 \uBCF4\uC774\uC9C0
      \uC54A\uB294 \uC778\uB3C4\uAC00 \uB2F9\uC2E0\uC744 \uCC28\uAC00\uC6B4 \uD759\uBC14\uB2E5\uC774
      \uC544\uB2CC, \uC9C4\uC815\uD55C \uB05D\uC73C\uB85C \uB370\uB824\uAC00 \uC8FC\uAE30\uB97C."
    m_Metadata:
      m_Items: []
  - m_Id: 40004
    m_Localized: "\uAE30\uC5B5\uD558\uC2DC\uB098\uC694. \uBE44\uB85D \uC721\uC2E0\uC740
      \uC783\uC73C\uC168\uC9C0\uB9CC, \uB2F9\uC2E0\uC758 \uC601\uD63C\uC5D0 \uAC01\uC778\uB41C
      \uC655\uAC00\uC758 \uD798\uC740 \uC5EC\uC804\uD788 \uC774 \uACA9\uC790\uD310
      \uC18D\uC5D0 \uC0B4\uC544 \uC228 \uC26C\uACE0 \uC788\uC5B4\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 40005
    m_Localized: "\uC0C1\uB150 \uC870\uAC01 \uD558\uB098\uB97C \uBD99\uC7A1\uC544
      \uC606\uC73C\uB85C \uBC00\uC5B4\uBCF4\uC138\uC694. \uADF8 \uCC30\uB098\uC758
      \uB4A4\uBC14\uB01C\uC774 \uB2F9\uC2E0\uC758 \uC6B4\uBA85\uC744 \uACB0\uC815\uC9D3\uAC8C
      \uB420 \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 40006
    m_Localized: "\uC870\uC2EC\uD558\uC138\uC694. \uBB34\uC758\uBBF8\uD55C \uD310\uB2E8\uC740
      \uC774\uBD84\uC758 \uB0A8\uC740 \uC228\uACB0\uC744 \uAC09\uC544\uBA39\uC744
      \uBFD0\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 40007
    m_Localized: "\uC0C1\uB150 \uC870\uAC01\uC744 \uD55C \uBC88 \uC62E\uAE38 \uB54C\uB9C8\uB2E4(\uD589\uB3D9\uB825
      \uC18C\uBAA8), \uC655\uC758 \uBC14\uC2A4\uB7EC\uC9C4 \uC601\uD63C\uC740 \uC870\uAE08\uC529
      \uC0AC\uADF8\uB77C\uB4E4 \uD14C\uB2C8\uAE4C\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 40008
    m_Localized: "\uAC19\uC740 \uC0C9\uC758 \uC0C1\uB150 \uC870\uAC01\uC744 3\uAC1C
      \uC774\uC0C1 \uBAA8\uC544 \uD130\uD2B8\uB9AC\uC138\uC694. \uADF8 \uCC30\uB098\uC758
      \uACB0\uD569\uC774 \uD30C\uAD34\uC758 \uBD88\uAF43\uC774 \uB418\uC5B4 \uB188\uB4E4\uC744
      \uBD88\uD0DC\uC6B8 \uAC83\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 40009
    m_Localized: "\uC774\uACF3\uC758 \uC2DC\uAC04\uC740 \uB2F9\uC2E0\uC758 \uC120\uD0DD\uD55C
      \uC218\uC5D0 \uB2EC\uB824 \uC788\uC5B4\uC694. \uB2F9\uC2E0\uC774 \uC0C1\uB150\uC870\uAC01\uC744
      \uC6C0\uC9C1\uC5EC \uD589\uB3D9\uC744 \uB9C8\uCE58\uB294 \uC21C\uAC04 \uC801\uB4E4\uB3C4
      \uC11C\uB298\uD55C \uCE7C\uB0A0\uC744 \uB4E4\uC774\uBC00 \uAC83\uC785\uB2C8\uB2E4.
      \uC2E0\uC911\uD558\uC154\uC57C \uD574\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 40010
    m_Localized: "\uBD89\uC740 \uC0C1\uB150 \uC870\uAC01\uC740 \uC801\uC744 \uAFF0\uB6AB\uB294
      \uAC80\uC785\uB2C8\uB2E4. \uC774\uAC83\uC744 \uC815\uB82C\uD574 \uB188\uB4E4\uC5D0\uAC8C
      \uCE58\uBA85\uC801\uC778 \uD53C\uD574\uB97C \uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 40011
    m_Localized: "\uD478\uB978 \uC0C1\uB150 \uC870\uAC01\uC740 \uC655\uC758 \uBC29\uD328\uC785\uB2C8\uB2E4.
      \uC801\uB4E4\uC758 \uC11C\uB298\uD55C \uCE7C\uB0A0\uC744 \uB9C9\uC544\uB0BC
      \uBC29\uC5B4\uB825\uC744 \uAC16\uCD94\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 40012
    m_Localized: "\uBD84\uD64D\uBE5B \uC0C1\uB150 \uC870\uAC01\uC740 \uBD80\uC11C\uC9C4
      \uC2EC\uC7A5\uC785\uB2C8\uB2E4. \uB2F9\uC2E0\uC758 \uC190\uAE38\uB85C \uC655\uC758
      \uC0DD\uBA85\uB825(HP)\uC744 \uB2E4\uC2DC \uCC44\uC6CC\uC8FC\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 40013
    m_Localized: "\uB179\uC0C9 \uC0C1\uB150 \uC870\uAC01\uC740 \uC655\uAC00\uC758
      \uBE44\uC220\uC785\uB2C8\uB2E4. \uD3C9\uBC94\uD55C \uC77C\uACA9\uC744 \uB118\uC5B4\uC11C\uB294
      \uAC15\uB825\uD55C \uAE30\uC220\uC744 \uD574\uBC29\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 50001
    m_Localized: "\uAC8C\uC784 \uC2DC\uC791"
    m_Metadata:
      m_Items: []
  - m_Id: 50002
    m_Localized: "\uAC8C\uC784 \uC885\uB8CC"
    m_Metadata:
      m_Items: []
  - m_Id: 50003
    m_Localized: "\uAC8C\uC784\uC744 \uC885\uB8CC\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    m_Metadata:
      m_Items: []
  - m_Id: 50004
    m_Localized: "\uC608"
    m_Metadata:
      m_Items: []
  - m_Id: 50005
    m_Localized: "\uC544\uB2C8\uC624"
    m_Metadata:
      m_Items: []
  - m_Id: 50006
    m_Localized: "\uC124\uC815"
    m_Metadata:
      m_Items: []
  - m_Id: 50007
    m_Localized: "\uBC30\uACBD\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 50008
    m_Localized: "\uD6A8\uACFC\uC74C"
    m_Metadata:
      m_Items: []
  - m_Id: 50009
    m_Localized: "\uD55C\uAD6D\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 50010
    m_Localized: English
    m_Metadata:
      m_Items: []
  - m_Id: 50011
    m_Localized: "\uB118\uAE30\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 50012
    m_Localized: "\uC774\uC804"
    m_Metadata:
      m_Items: []
  - m_Id: 50013
    m_Localized: "\uACC4\uC18D"
    m_Metadata:
      m_Items: []
  - m_Id: 50014
    m_Localized: "\uB2EB\uAE30"
    m_Metadata:
      m_Items: []
  - m_Id: 50015
    m_Localized: "\uC77C\uC2DC\uC815\uC9C0"
    m_Metadata:
      m_Items: []
  - m_Id: 50016
    m_Localized: "\uAC8C\uC784 \uC7AC\uAC1C"
    m_Metadata:
      m_Items: []
  - m_Id: 50017
    m_Localized: "\uBA54\uC778\uD654\uBA74"
    m_Metadata:
      m_Items: []
  - m_Id: 50018
    m_Localized: "\uBA54\uC778\uD654\uBA74\uC73C\uB85C \uB3CC\uC544\uAC00\uBA74 \uD604\uC7AC
      \uC9C4\uD589 \uC911\uC778 \uBAA8\uB4E0 \uB370\uC774\uD130\uAC00 \uC0AC\uB77C\uC9D1\uB2C8\uB2E4.
      \\n\uACC4\uC18D\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    m_Metadata:
      m_Items: []
  - m_Id: 50019
    m_Localized: "\uD589\uB3D9\uB825"
    m_Metadata:
      m_Items: []
  - m_Id: 50020
    m_Localized: "\uD134 \uC885\uB8CC"
    m_Metadata:
      m_Items: []
  - m_Id: 50021
    m_Localized: "\uD589\uB3D9\uB825\uC744 1 \uC18C\uBAA8\uD558\uBA70\n\uD37C\uC990\uD310\uC744
      \uCD08\uAE30\uD654\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?"
    m_Metadata:
      m_Items: []
  - m_Id: 50022
    m_Localized: "\uD134\uC744 \uC885\uB8CC\uD560\uAE4C\uC694?"
    m_Metadata:
      m_Items: []
  - m_Id: 50023
    m_Localized: "\uCDE8\uC18C"
    m_Metadata:
      m_Items: []
  - m_Id: 60001
    m_Localized: "[\uBCBC\uB824\uC9C4 \uCE7C\uB0A0]\\n\uACF5\uACA9 \uBE14\uB85D\uC758
      \uACF5\uACA9\uB825\uC774 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 60002
    m_Localized: "[\uACAC\uACE0\uD55C \uAC11\uC8FC]\\n\uBC29\uC5B4 \uBE14\uB85D\uC758
      \uC274\uB4DC\uB7C9\uC774 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 60003
    m_Localized: "[\uBC31\uC131\uC758 \uC5FC\uC6D0]\\n\uB9DD\uAD6D\uC758 \uC655\uC758
      \uCCB4\uB825\uC774 \uD68C\uBCF5\uB429\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 60004
    m_Localized: "[\uC601\uD63C\uC758 \uBD09\uD5CC]\\n\uCCB4\uB825 \uBE14\uB85D\uC758
      \uCCB4\uB825 \uD68C\uBCF5\uB7C9\uC774 \uC0C1\uC2B9\uD569\uB2C8\uB2E4."
    m_Metadata:
