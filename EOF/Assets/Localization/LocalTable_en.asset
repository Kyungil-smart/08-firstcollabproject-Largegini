  - m_Id: 50003
    m_Localized: End your journey here?
    m_Metadata:
      m_Items: []
  - m_Id: 50004
    m_Localized: YES
    m_Metadata:
      m_Items: []
  - m_Id: 50005
    m_Localized: NO
